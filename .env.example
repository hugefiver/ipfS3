# S3 Gateway credentials (replace with your own strong values)
IPFS_S3_ACCESS_KEY_ID=test
IPFS_S3_SECRET_ACCESS_KEY=test

# Master key for SSE-S3 encryption (hex-encoded 32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
# WARNING: Do NOT use all-zeros in production. The gateway will refuse to
#          start with an all-zero key in release builds.
IPFS_S3_MASTER_KEY=a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f90

# Cloudflare Tunnel Token (for public access via Cloudflare)
CLOUDFLARE_TUNNEL_TOKEN=
